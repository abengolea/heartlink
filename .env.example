# ===========================================
# HeartLink - Variables de Entorno para Local
# ===========================================
# Copia este archivo a .env.local y completa los valores.
# cp .env.example .env.local

# -------------------------------------------
# Firebase (OBLIGATORIO para funcionar)
# -------------------------------------------
# Obtén estos valores en: Firebase Console → Configuración del proyecto → General

# Cliente (frontend) - prefijo NEXT_PUBLIC_ expone al navegador
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=heartlink-f4ftq
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=heartlink-f4ftq.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Servidor (backend) - Service Account Key (JSON completo como string)
# Firebase Console → Configuración → Cuentas de servicio → Generar nueva clave
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
FIREBASE_STORAGE_BUCKET=heartlink-f4ftq.firebasestorage.app

# Requerido por firebase-admin v12 para Auth (evita error "Caller does not have required permission")
# Usa el mismo ID que tu proyecto de Firebase
GOOGLE_CLOUD_QUOTA_PROJECT=heartlink-f4ftq

# -------------------------------------------
# App
# -------------------------------------------
# URL base de la app (para enlaces compartidos, emails, etc.)
# En producción: https://heartlink--heartlink-f4ftq.us-central1.hosted.app
NEXT_PUBLIC_APP_URL=https://heartlink--heartlink-f4ftq.us-central1.hosted.app

# Email que puede promoverse a admin cuando no hay administradores (bootstrap)
ADMIN_BOOTSTRAP_EMAIL=abengolea1@gmail.com

# -------------------------------------------
# Opcionales (según funcionalidades que uses)
# -------------------------------------------

# Genkit / IA (Gemini)
GEMINI_API_KEY=
# o GOOGLE_API_KEY=

# Mercado Pago (suscripciones)
MERCADOPAGO_ACCESS_TOKEN=

# DLocal Go (pagos - alternativa a MercadoPago)
# Testing: https://api-sbx.dlocalgo.com | Live: https://api.dlocalgo.com
DLOCAL_API_KEY=
DLOCAL_SECRET_KEY=
DLOCAL_BASE_URL=https://api.dlocalgo.com
DLOCAL_WEBHOOK_URL=https://heartlink--heartlink-f4ftq.us-central1.hosted.app/api/dlocal/webhook
DLOCAL_RETURN_URL=https://heartlink--heartlink-f4ftq.us-central1.hosted.app/dashboard/subscription
# true = Sandbox (pruebas), false = Producción
DLOCAL_SANDBOX=true

# -------------------------------------------
# WhatsApp - Envío (HeartLink solo envía, no recibe)
# -------------------------------------------
# Las 5 variables abajo son las únicas que HeartLink necesita para WhatsApp.
# Regla: MESSENGER_VERIFY_TOKEN / WHATSAPP_VERIFY_TOKEN → solo en NotificasHub (hub central que recibe estados de entrega).
# HeartLink no tiene webhook propio; envía mensajes a través de NotificasHub.

PHONE_NUMBER_ID=693302653873170
# WHATSAPP_TOKEN — el token permanente del System User HeartLink_WhatsApp
WHATSAPP_TOKEN=

# NotificasHub - Firebase del hub de notificaciones (envío)
NOTIFICASHUB_PROJECT_ID=studio-3864746689-59018
NOTIFICASHUB_CLIENT_EMAIL=firebase-adminsdk-fbsvc@studio-3864746689-59018.iam.gserviceaccount.com
NOTIFICASHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Idioma de la plantilla: es, es_AR, es_ES, etc. Ver en Meta Business Manager.
# WHATSAPP_TEMPLATE_LANGUAGE=es_AR
# NEXT_PUBLIC_WHATSAPP_DISPLAY_NUMBER=

# Costo estimado por mensaje (ARS) para estadísticas admin. Opcional.
# WHATSAPP_ESTIMATED_COST_PER_MESSAGE_ARS=50

# --- Recepción vía NotificasHub (operador envía video por WhatsApp) ---
# NotificasHub recibe el webhook de Meta y reenvía a HeartLink. Debe coincidir con NotificasHub.
INTERNAL_SECRET=

# URL de NotificasHub para registrar usuarios (register-user). HeartLink llama aquí al crear/actualizar usuarios con phone.
NOTIFICASHUB_URL=https://notificashub--studio-3864746689-59018.us-east4.hosted.app

# --- Variables que HeartLink NO requiere (solo NotificasHub) ---
# WHATSAPP_VERIFY_TOKEN  → webhook de NotificasHub (recibe estados "entregado", "leído", etc.)
# MESSENGER_VERIFY_TOKEN → mismo uso
# META_APP_SECRET
# En NotificasHub .env: HEARTLINK_URL=https://tu-heartlink.vercel.app (o URL de producción)

# Cron / tareas programadas
CRON_SECRET_TOKEN=heartlink-cron-2025

# Emails: se usa la extensión Firebase Trigger Email (firestore-send-email).
# Los emails se escriben en la colección "mail" y la extensión los envía.
# Configura SMTP en extensions/firestore-send-email.env (ej. Gmail).
